SECRET_KEY=django-insecure-syncspace-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ✅ Change from sqlite to PostgreSQL (db = service name in docker-compose)
DATABASE_URL=postgresql://syncspace:syncspace_pass@db:5432/syncspace

# ✅ Change from localhost to redis (redis = service name in docker-compose)
REDIS_URL=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password